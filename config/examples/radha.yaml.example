# Example cluster config for an AMD-internal cluster (Radha).
# Paths, DNS entries, and registry URLs below are AMD-specific and will not
# work outside AMD infrastructure. Use this as a reference when writing your
# own cluster config.
cluster:
  name: radha
  head-host-command: "$(dig +short $(hostname).amd.com)"
  models-dir: /shared/omnihub/models
  shared-dir: /home/shared/projs/omnihub
  data-dir: /home/shared/projs/omnihub/data
  results-dir: $HOME/results/omnihub/$SLURM_JOB_ID
  container-platforms:
    - apptainer
    - docker
  docker-image: "mkmhub.amd.com/sw-radops-dev/omnihub/radha"
  subsets:
    - partition: mi210-low
      gpu: mi210
      num-gpus: 4
      num-nodes: 7
    - partition: mi210
      gpu: mi210
      num-gpus: 4
      num-nodes: 7
    - partition: mi300x
      gpu: mi300
      num-gpus: 8
      num-nodes: 2
