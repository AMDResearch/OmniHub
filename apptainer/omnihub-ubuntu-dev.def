Bootstrap: docker
From: rocm/dev-ubuntu-22.04:6.2-complete
Stage: spython-base

%files
docker/fix-host-owner.sh /usr/local/bin/fix-host-owner
docker/requirements.txt /omnihub/requirements.txt
%post
# Image file to run LLAMA models with ROCm
#
# This container is meant to be used for prototyping an automated pipeline and
# collect performance data in our clusters.
#
# It builds and runs everything as root; ownership of any output may need to
# be fixed to ensure they can be read outside the container. If executed
# mounting the /host-home volume (with docker/run-docker-ubuntu-dev.sh) or running in
# host-mounted directories, the `fix-host-owner' script can be used to make sure any
# directory is owned by the same user running the container.


CONDA_INSTALLER=https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh
OMNIPERF_TARBALL=https://github.com/ROCm/omniperf/releases/download/v2.0.0-RC1/omniperf-2.0.0-RC1.tar.gz
OMNITRACE_INSTALLER=https://github.com/ROCm/omnitrace/releases/download/v1.11.4/omnitrace-1.11.4-ubuntu-22.04-ROCm-60200-PAPI-OMPT-Python3.sh
PYTORCH_URL=https://download.pytorch.org/whl/rocm6.1

DEBIAN_FRONTEND=noninteractive

CONDA_DIR=/opt/conda
OMNIPERF_DIR=/opt/omniperf
OMNITRACE_DIR=/opt/omnitrace
PATH="$CONDA_DIR/bin:$OMNIPERF_DIR/bin:$OMNITRACE_DIR/bin:$PATH"
PYTHONPATH="$CONDA_DIR/lib/python3.9/site-packages:$OMNITRACE_DIR/lib/python/site-packages:$PYTHONPATH"

apt update && \
apt install -y \
libibverbs1 \
ibverbs-utils \
ibverbs-providers \
cmake \
git \
vim \
wget \
locales \
iproute2 \
net-tools \
glibc-source && \
rm -rf /var/cache/apt/archives /var/lib/apt/lists && \
locale-gen en_US.UTF-8

mkdir -p /omnihub
cd /omnihub

wget --quiet $CONDA_INSTALLER -O /tmp/miniconda.sh && \
bash /tmp/miniconda.sh -b -p $CONDA_DIR && \
rm -f /tmp/miniconda.sh

conda update -y conda && \
conda init && \
conda install -c conda-forge -y python=3.9

pip install torch torchvision torchaudio --index-url $PYTORCH_URL

mkdir -p /omnihub
cd /omnihub
wget --quiet $OMNIPERF_TARBALL -O /tmp/omniperf.tar.gz && \
tar xfz /tmp/omniperf.tar.gz -C /tmp && \
omniperf_basedir=$(basename $OMNIPERF_TARBALL .tar.gz) && \
cd /tmp/$omniperf_basedir && \
python3 -m pip install -r requirements.txt && \
mkdir -p build && \
cd build && \
cmake -DCMAKE_INSTALL_PREFIX=${OMNIPERF_DIR} \
-DPYTHON_DEPS=${CONDA_DIR}/lib/python3.9/site-packages \
..  && \
make install && \
rm -f /tmp/omniperf.tar.gz && \
rm -rf /tmp/$omniperf_basedir

mkdir -p /omnihub
cd /omnihub
wget --quiet $OMNITRACE_INSTALLER -O /tmp/omnitrace-install.sh && \
mkdir $OMNITRACE_DIR && \
cd $OMNITRACE_DIR && \
bash /tmp/omnitrace-install.sh --prefix=$OMNITRACE_DIR --exclude-subdir && \
cd && \
rm -f /tmp/omnitrace-install.sh


# Currently we support MI210/MI250/MI300
PYTORCH_ROCM_ARCH="gfx90a;gfx942"

## Hugging Face
mkdir -p /omnihub
cd /omnihub
git clone https://github.com/ROCm/bitsandbytes.git && \
cd bitsandbytes && \
git checkout rocm_enabled && \
pip install -U pip && \
pip install -r requirements-dev.txt && \
cmake -DCOMPUTE_BACKEND=hip -DBNB_ROCM_ARCH=${PYTORCH_ROCM_ARCH} -S . && \
make && \
pip install . && \
cd && \
rm -rf /omnihub/bitsandbytes

# FIXME(aaji): Llama-recipes and vLLM dependencies are somewhat off, so
# commenting out llama-recipes until we feel that we really need it
# WORKDIR /omnihub
# RUN git clone https://github.com/meta-llama/llama-recipes.git && \
#     cd llama-recipes && \
#     git checkout v0.0.3 && \
#     pip install -U pip setuptools && \
#     pip install -e . && \
#     cd && \
#     rm -rf /omnihub/llama-recipes

pip install -r /omnihub/requirements.txt && \
rm -f /omnihub/requirements.txt

## vLLM
wget --quiet https://github.com/ROCm/flash-attention/releases/download/v2.5.9post1-cktile-vllm/flash_attn-2.5.9.post1-cp39-cp39-linux_x86_64.whl -P /tmp && \
pip install /tmp/flash_attn-2.5.9.post1-cp39-cp39-linux_x86_64.whl && \
rm -f /tmp/flash_attn-2.5.9.post1-cp39-cp39-linux_x86_64.whl
# # Install vLLM
# TODO/FIXME (aaji) Below env vars are set based on MLSE's dockerfile:
# https://github.com/ROCm/vllm/blob/48c0cb4f2f4d8aa09c80a90faea72cd8d093a878/Dockerfile.rocm#L268-L272
# The hope is that we do not have to explicitly set these when we build apptainer images from pre-baked docker images
# from dockerhub or MLSE internal artifactory
RAY_EXPERIMENTAL_NOSET_ROCR_VISIBLE_DEVICES=1
TOKENIZERS_PARALLELISM=false
HIP_FORCE_DEV_KERNARG=1
# Make sure punica kernels are built (for LoRA)
# ENV VLLM_INSTALL_PUNICA_KERNELS=1
# # Apply the patch to ROCM 6.1 (requires root permission)
mkdir -p /omnihub
cd /omnihub
git clone https://github.com/ROCm/vllm.git && \
cd vllm && \
git checkout v0.6.0 && \
pip install numba scipy && \
pip install "numpy<2" && \
pip install "cmake>3.26" && \
pip install -r requirements-rocm.txt && \
pip install -U openai && \
wget --quiet -N https://github.com/ROCm/vllm/raw/v0.6.1_rocm/rocm_patch/libamdhip64.so.6 -P /opt/rocm/lib && \
rm -f "$(python3 -c 'import torch; print(torch.__path__[0])')"/lib/libamdhip64.so*

mkdir -p /omnihub
cd /omnihub
mkdir /vllm && \
cd vllm && \
python3 setup.py clean --all && python3 setup.py bdist_wheel --dist-dir=/vllm
# Build gradlib
# FIXME(aaji): gradlib is needed in the ROCm-optimized branch of vLLM, but that branch is currently buggy for tensor parallel inference; commenting out for now.
# WORKDIR /omnihub
# RUN cd vllm/gradlib && \
#     python3 setup.py clean --all && python3 setup.py bdist_wheel --dist-dir=/vllm

# Build amdsmi wheel always (vLLM dependency).
cd /opt/rocm/share/amd_smi \
&& python3 -m pip wheel . --wheel-dir=/vllm

cd /vllm && \
pip install *.whl && \
rm -rf /vllm

# Ensure consistent entry point for both docker and the converted apptainer image
mkdir -p /omnihub
cd /omnihub
%environment
export CONDA_DIR=/opt/conda
export OMNIPERF_DIR=/opt/omniperf
export OMNITRACE_DIR=/opt/omnitrace
export PATH="$CONDA_DIR/bin:$OMNIPERF_DIR/bin:$OMNITRACE_DIR/bin:$PATH"
export PYTHONPATH="$CONDA_DIR/lib/python3.9/site-packages:$OMNITRACE_DIR/lib/python/site-packages:$PYTHONPATH"
export PYTORCH_ROCM_ARCH="gfx90a;gfx942"
export RAY_EXPERIMENTAL_NOSET_ROCR_VISIBLE_DEVICES=1
export TOKENIZERS_PARALLELISM=false
export HIP_FORCE_DEV_KERNARG=1
%runscript
cd /omnihub
exec /bin/bash "$@"
%startscript
cd /omnihub
exec /bin/bash "$@"
